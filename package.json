{
  "name": "insilico-matlab",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "tsc -p tsconfig.test.json && echo '{\"type\":\"commonjs\"}' > .test-dist/package.json && node --test '.test-dist/**/*.test.js'",
    "oracle:generate": "tsc -p tsconfig.test.json && node matlab/test/oracle/generate.mjs",
    "oracle:coverage": "tsc -p tsconfig.test.json && node matlab/test/oracle/coverage.mjs",
    "oracle:audit": "tsc -p tsconfig.test.json && node matlab/test/oracle/registry-audit.mjs",
    "oracle:base-audit": "tsc -p tsconfig.test.json && node matlab/test/oracle/base-audit.mjs",
    "clean": "rm -rf .test-dist dist",
    "registry:audit": "tsc -p tsconfig.test.json && node matlab/test/oracle/registry-dups.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  }
}
